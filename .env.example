# Vorlage für API-Keys. Kopiere diese Datei zu `.env` und trage deine Keys ein:
#   cp .env.example .env
# Lade sie pro Shell-Session mit:
#   set -a; source .env; set +a
# Die Datei `.env` ist über .gitignore vom Repo ausgenommen — Keys nicht committen.

# Pflicht: Anthropic Vision-API (Claude). Console: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional, aber empfohlen: Google-Books-API-Key.
# Ohne Key:   1.000 Requests/Tag (reicht für 1 Trockenlauf).
# Mit Key:  100.000 Requests/Tag.
# Console:  https://console.cloud.google.com/ → APIs & Services → "Books API" aktivieren → Credentials → API key
GOOGLE_BOOKS_API_KEY=
